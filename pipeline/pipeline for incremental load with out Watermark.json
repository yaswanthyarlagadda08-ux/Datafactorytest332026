{
	"name": "pipeline for incremental load with out Watermark",
	"properties": {
		"activities": [
			{
				"name": "Copy data when new file arrived",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "DelimitedTextSource",
						"storeSettings": {
							"type": "AzureBlobFSReadSettings",
							"recursive": true,
							"enablePartitionDiscovery": false
						},
						"formatSettings": {
							"type": "DelimitedTextReadSettings"
						}
					},
					"sink": {
						"type": "DelimitedTextSink",
						"storeSettings": {
							"type": "AzureBlobFSWriteSettings"
						},
						"formatSettings": {
							"type": "DelimitedTextWriteSettings",
							"quoteAllText": true,
							"fileExtension": ".txt"
						}
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "ds_datalakesource",
						"type": "DatasetReference",
						"parameters": {
							"dssoucre_parameter": {
								"value": "@pipeline().parameters.pip_file",
								"type": "Expression"
							}
						}
					}
				],
				"outputs": [
					{
						"referenceName": "ds_datalakesink",
						"type": "DatasetReference",
						"parameters": {
							"dssink_parameter": {
								"value": "@pipeline().parameters.pip_file",
								"type": "Expression"
							}
						}
					}
				]
			}
		],
		"parameters": {
			"pip_file": {
				"type": "string"
			}
		},
		"annotations": []
	}
}